{
  "manifest_version": 3,
  "name": "Time logging reminder",
  "version": "1.0.4",
  "description": "Shows a reminder to log your time on Google Docs, Sheets, NotebookLM, finance sites, and other URLs you choose.",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://docs.google.com/document/*",
    "https://docs.google.com/spreadsheets/*",
    "https://notebooklm.google.com/*",
    "https://*.fidelity.com/*",
    "https://*.usbank.com/*",
    "https://*.schwab.com/*",
    "https://humaninterest.com/*",
    "https://*.humaninterest.com/*",
    "https://*.tradingview.com/*",
    "https://twitter.com/*",
    "https://*.twitter.com/*",
    "https://x.com/*",
    "https://*.x.com/*"
  ],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Time logging reminder",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
